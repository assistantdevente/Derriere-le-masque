<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Paiement - Derrière le Masque</title>
    <style>
        body { background-color: #2c2c2c; color: #ffffff; font-family: 'Georgia', serif; padding: 40px; text-align: center; }
        .container { max-width: 450px; margin: auto; background-color: #3d3d3d; padding: 30px; border-radius: 15px; border: 2px solid #d4af37; box-shadow: 0px 10px 30px rgba(0,0,0,0.5); box-sizing: border-box; }
        h1 { color: #d4af37; text-transform: uppercase; font-size: 1.5em; margin-bottom: 20px; }
        .price-tag { font-size: 3em; color: #d4af37; font-weight: bold; margin: 20px 0; border: 1px solid #555; padding: 10px; border-radius: 5px; background: #333; }
        .benefits { text-align: left; margin: 20px 0; font-size: 0.9em; border-left: 3px solid #d4af37; padding-left: 15px; }
        
        /* Voici le réglage pour le bouton centré */
        .paypal-btn { 
            background-color: #0070ba; 
            color: white; 
            text-decoration: none; 
            display: block; 
            width: 100%; 
            padding: 15px 0; 
            font-size: 1.2em; 
            font-weight: bold; 
            border-radius: 5px; 
            margin: 30px 0; 
            box-sizing: border-box;
            transition: 0.3s;
        }
        .paypal-btn:hover { background-color: #005ea6; transform: scale(1.02); }
        .secure-text { font-size: 0.8em; color: #aaa; margin-top: 15px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Analyse Terminée</h1>
        <p>Vos réponses ont été traitées. Votre profil est prêt.</p>
        
        <div class="price-tag">15 €</div>

        <div class="benefits">
            <p>✅ Votre profil complet en 15 paragraphes détaillés</p>
            <p>✅ Analyse envoyée instantanément par e-mail</p>
            <p>✅ Accès prioritaire au programme de parrainage</p>
            <p>✅ Bonus : Gagnez 3 € par ami qui fait le test</p>
        </div>

<form action="https://www.paypal.com" method="post" id="paypal-form">
    <input type="hidden" name="cmd" value="_xclick">
    
    <!-- 1. TON EMAIL (Pense à mettre ton vrai email PayPal) -->
    <input type="hidden" name="business" value="ASSISTANTDEVENTE@GMAIL.COM">
    
    <input type="hidden" name="item_name" value="Analyse Derrière le Masque">
    
    <!-- 2. LE PRIX (0.01 pour test, 15.00 après) -->
    <input type="hidden" name="amount" value="0.01">
    <input type="hidden" name="currency_code" value="EUR">

    <!-- 3. LES REDIRECTIONS -->
    <input type="hidden" name="return" value="https://derri-re-le-masque-production.up.railway.app">
    <input type="hidden" name="cancel_return" value="https://derri-re-le-masque-production.up.railway.app">
    <input type="hidden" name="no_shipping" value="1">

    <!-- 4. LE MARQUEUR SECRET (Pour savoir qui a parrainé l'ami) -->
    <input type="hidden" name="custom" id="custom_field" value="">

    <button type="submit" class="paypal-btn" style="background:#0070ba; color:white; padding:15px; width:100%; border:none; border-radius:5px; font-weight:bold; cursor:pointer;">
        Payer et débloquer mon analyse
    </button>
</form>

<script>
    // Ce petit script regarde si l'ami est venu via un lien ?ref=NOM
    // Si oui, il met "NOM" dans le champ secret 'custom' pour PayPal
    const urlParams = new URLSearchParams(window.location.search);
    const parrain = urlParams.get('ref');
    if (parrain) {
        document.getElementById('custom_field').value = parrain;
    }
</script>

        
        <p class="secure-text">🔒 Transaction sécurisée et confidentielle</p>
    </div>
</body>
</html>
